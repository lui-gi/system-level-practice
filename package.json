{
  "name": "system-level-practice",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"tsx watch server/src/index.ts\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "lint": "npm run lint --workspace=client"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
